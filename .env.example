# Network
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0xyour_private_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Deployment
TREASURY_ADDRESS=0xyour_treasury_address_here
# Operational venue wallets
SCANNER_ADDRESSES=0xscanner1,0xscanner2
SCANNER_ADMIN_ADDRESSES=0xscanneradmin1,0xscanneradmin2
PAUSER_ADDRESSES=0xpauser1,0xpauser2
TICKET_NAME=ChainTicket Event
TICKET_SYMBOL=CTK
EVENT_ID=main-event
PRIMARY_PRICE_POL=0.1
MAX_SUPPLY=100
BASE_TOKEN_URI=ipfs://chainticket/base/
COLLECTIBLE_BASE_URI=ipfs://chainticket/collectible/

# Optional event registry / factory publication
DEPLOY_CHAIN_TICKET_FACTORY=false
CHAIN_TICKET_FACTORY_ADDRESS=
# After deploy, copy the real deployed block into bff/.env and frontend/.env.
# Do not leave DEPLOYMENT_BLOCK at 0 once real single-event addresses are wired.

# Demo lineup deployment defaults
DEMO_PRIMARY_PRICE_POL=0.12
DEMO_MAX_SUPPLY=150
DEMO_BASE_TOKEN_URI_ROOT=http://localhost:8787/demo-assets/
DEMO_COLLECTIBLE_BASE_URI_ROOT=http://localhost:8787/demo-assets/

# Optional governance handoff
# Keep long-term admin on a multisig/timelock, not on day-to-day ops wallets.
GOVERNANCE_ADMIN_ADDRESS=0xmultisig_or_admin_here
TIMELOCK_ENABLED=false
TIMELOCK_MIN_DELAY_SECONDS=86400
TIMELOCK_PROPOSERS=0xproposer1,0xproposer2
TIMELOCK_EXECUTORS=0xexecutor1,0xexecutor2

# Demo script input (set after deploy)
TICKET_NFT_ADDRESS=0xyour_ticket_contract
MARKETPLACE_ADDRESS=0xyour_marketplace_contract
CHECKIN_REGISTRY_ADDRESS=0xyour_checkin_registry_contract
DEMO_FUND_FAN_A_POL=0.30
DEMO_FUND_FAN_B_POL=0.20
DEMO_FUND_SCANNER_POL=0.03
DEMO_ADMIN_GAS_RESERVE_POL=0.02
