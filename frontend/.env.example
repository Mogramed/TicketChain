# Frontend environment (Polygon Amoy)
# SECURITY: keep frontend .env limited to VITE_* keys only.
# VITE_AMOY_RPC_URL is kept for wallet network metadata and explicit no-BFF development only.
VITE_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
VITE_EXPLORER_TX_BASE_URL=https://amoy.polygonscan.com/tx/
# Required in single-event mode: set the real deployment block for the configured contracts.
VITE_DEPLOYMENT_BLOCK=12345678
VITE_DEFAULT_EVENT_ID=main-event
VITE_DEFAULT_EVENT_NAME=Main Event
VITE_TICKET_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CHECKIN_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
# Recommended on Amoy: keep BFF reads enabled so the browser does not hit the public RPC for indexed views.
VITE_API_BASE_URL=http://localhost:8787
VITE_FACTORY_ADDRESS=
VITE_GOVERNANCE_TIMELOCK_ADDRESS=
VITE_GOVERNANCE_MIN_DELAY_SECONDS=0
VITE_GOVERNANCE_PORTAL_URL=
VITE_CHAIN_ENV=amoy
VITE_FEATURE_FLAGS=timeline,watchlist,scanner,organizer
