# Frontend environment (Polygon Amoy)
# SECURITY: keep frontend .env limited to VITE_* keys only.
VITE_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
VITE_EXPLORER_TX_BASE_URL=https://amoy.polygonscan.com/tx/
VITE_DEPLOYMENT_BLOCK=0
VITE_TICKET_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CHECKIN_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_API_BASE_URL=http://localhost:8787
VITE_CHAIN_ENV=amoy
VITE_FEATURE_FLAGS=timeline,watchlist,scanner,organizer
